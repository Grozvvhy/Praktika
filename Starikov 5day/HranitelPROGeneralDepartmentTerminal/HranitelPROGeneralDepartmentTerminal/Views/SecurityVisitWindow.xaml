<Window x:Class="HranitelPROGeneralDepartmentTerminal.Views.SecurityVisitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление посещением" Height="600" Width="900"
        WindowStartupLocation="CenterOwner" MinHeight="500" MinWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Информация о заявке -->
            <GroupBox Header="Заявка" Grid.Row="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="ID:"/>
                    <TextBlock x:Name="RequestIdText" Grid.Column="1"/>
                    <TextBlock Text="Тип:" Grid.Column="2"/>
                    <TextBlock x:Name="TypeText" Grid.Column="3"/>
                    <TextBlock Text="Подразделение:" Grid.Row="1"/>
                    <TextBlock x:Name="DepartmentText" Grid.Column="1" Grid.Row="1"/>
                    <TextBlock Text="Ответственный:" Grid.Row="1" Grid.Column="2"/>
                    <TextBlock x:Name="EmployeeText" Grid.Column="3" Grid.Row="1"/>
                    <TextBlock Text="Цель:" Grid.Row="2"/>
                    <TextBlock x:Name="PurposeText" Grid.Column="1" Grid.Row="2" TextWrapping="Wrap" Grid.ColumnSpan="3"/>
                </Grid>
            </GroupBox>

            <!-- Посетители -->
            <GroupBox Header="Посетители" Grid.Row="1" Margin="0,10">
                <DataGrid x:Name="VisitorsDataGrid" AutoGenerateColumns="False" Height="200">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                        <DataGridTextColumn Header="ФИО" Width="200">
                            <DataGridTextColumn.Binding>
                                <MultiBinding StringFormat="{}{0} {1} {2}">
                                    <Binding Path="LastName"/>
                                    <Binding Path="FirstName"/>
                                    <Binding Path="MiddleName"/>
                                </MultiBinding>
                            </DataGridTextColumn.Binding>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Вход" Binding="{Binding EntryTime, StringFormat=dd.MM.yyyy HH:mm}" Width="130"/>
                        <DataGridTextColumn Header="Прибытие" Binding="{Binding ArrivalTime, StringFormat=dd.MM.yyyy HH:mm}" Width="130"/>
                        <DataGridTextColumn Header="Убытие из отд." Binding="{Binding DepartureTime, StringFormat=dd.MM.yyyy HH:mm}" Width="130"/>
                        <DataGridTextColumn Header="Выход" Binding="{Binding ExitTime, StringFormat=dd.MM.yyyy HH:mm}" Width="130"/>
                        <DataGridCheckBoxColumn Header="Нарушение" Binding="{Binding ViolationTime}" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <!-- Панель действий -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10">
                <Button x:Name="AllowEntryButton" Content="Разрешить вход" Click="AllowEntryButton_Click" Width="120" Height="30" Margin="5"/>
                <Button x:Name="AllowExitButton" Content="Разрешить выход" Click="AllowExitButton_Click" Width="120" Height="30" Margin="5"/>
                <Button Content="Закрыть" Click="CloseButton_Click" Width="100" Height="30" Margin="5"/>
            </StackPanel>

            <!-- Статус -->
            <TextBlock x:Name="StatusTextBlock" Grid.Row="3" TextWrapping="Wrap" Margin="0,10"/>
        </Grid>
    </ScrollViewer>
</Window>