<Window x:Class="HranitelPROGeneralDepartmentTerminal.Views.RequestReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Формальная проверка заявки" Height="700" Width="900"
        WindowStartupLocation="CenterOwner" MinHeight="600" MinWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Информация о заявке -->
            <GroupBox Header="Данные заявки" Grid.Row="0" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="ID:" VerticalAlignment="Center"/>
                    <TextBlock x:Name="RequestIdText" Grid.Column="1" VerticalAlignment="Center"/>

                    <TextBlock Text="Тип:" Grid.Row="1" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TypeText" Grid.Column="1" Grid.Row="1" VerticalAlignment="Center"/>

                    <TextBlock Text="Цель:" Grid.Row="2" VerticalAlignment="Center"/>
                    <TextBlock x:Name="PurposeText" Grid.Column="1" Grid.Row="2" TextWrapping="Wrap"/>

                    <TextBlock Text="Подразделение:" Grid.Row="3" VerticalAlignment="Center"/>
                    <TextBlock x:Name="DepartmentText" Grid.Column="1" Grid.Row="3" VerticalAlignment="Center"/>

                    <TextBlock Text="Ответственный:" Grid.Row="4" VerticalAlignment="Center"/>
                    <TextBlock x:Name="EmployeeText" Grid.Column="1" Grid.Row="4" VerticalAlignment="Center"/>

                    <TextBlock Text="Даты:" Grid.Column="2" VerticalAlignment="Center"/>
                    <TextBlock x:Name="DatesText" Grid.Column="3" VerticalAlignment="Center"/>

                    <TextBlock Text="Статус:" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusText" Grid.Column="3" Grid.Row="1" VerticalAlignment="Center"/>

                    <TextBlock Text="Email заявителя:" Grid.Row="2" Grid.Column="2" VerticalAlignment="Center"/>
                    <TextBlock x:Name="UserEmailText" Grid.Column="3" Grid.Row="2" TextWrapping="Wrap"/>
                </Grid>
            </GroupBox>

            <!-- Список посетителей -->
            <GroupBox Header="Посетители" Grid.Row="1" Margin="0,0,0,10">
                <DataGrid x:Name="VisitorsDataGrid" AutoGenerateColumns="False" Height="180" IsReadOnly="True" FontSize="11">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="100"/>
                        <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="100"/>
                        <DataGridTextColumn Header="Отчество" Binding="{Binding MiddleName}" Width="100"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="160"/>
                        <DataGridTextColumn Header="Паспорт" Binding="{Binding PassportSeries}" Width="80"/>
                        <DataGridTextColumn Header="Номер" Binding="{Binding PassportNumber}" Width="90"/>
                        <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <!-- Сообщение о чёрном списке -->
            <TextBlock x:Name="BlacklistMessageText" Grid.Row="2" Foreground="Red" FontWeight="Bold" 
                       Margin="0,5" Visibility="Collapsed" TextWrapping="Wrap"/>

            <!-- Панель действий -->
            <StackPanel x:Name="ActionPanel" Grid.Row="3" Orientation="Horizontal" Margin="0,15">
                <TextBlock Text="Дата посещения:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <DatePicker x:Name="VisitDatePicker" Width="120" Margin="0,0,15,0"/>
                <TextBlock Text="Время посещения:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="VisitTimeTextBox" Width="80" Text="09:00" Margin="0,0,15,0"/>
                <TextBlock Text="Статус:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="StatusComboBox" Width="140" DisplayMemberPath="Name" SelectedValuePath="Id"/>
            </StackPanel>

            <!-- Кнопки -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ApproveButton" Content="Одобрить" Click="ApproveButton_Click" 
                        Width="100" Height="30" Margin="5"/>
                <Button x:Name="RejectButton" Content="Отклонить" Click="RejectButton_Click" 
                        Width="100" Height="30" Margin="5"/>
                <Button Content="Закрыть" Click="CloseButton_Click" Width="100" Height="30" Margin="5"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>