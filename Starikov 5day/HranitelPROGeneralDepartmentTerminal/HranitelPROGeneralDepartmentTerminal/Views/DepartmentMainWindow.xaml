<Window x:Class="HranitelPROGeneralDepartmentTerminal.Views.DepartmentMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Терминал сотрудника подразделения" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen" MinHeight="600" MinWidth="1000"
        ResizeMode="CanResize" WindowState="Maximized">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок с информацией -->
        <Border Grid.Row="0" Background="LightSteelBlue" Padding="10" Margin="5">
            <StackPanel>
                <TextBlock x:Name="HeaderTextBlock" FontSize="16" FontWeight="Bold" TextWrapping="Wrap"/>
                <TextBlock x:Name="SubHeaderTextBlock" FontSize="12" TextWrapping="Wrap" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Панель фильтров -->
        <GroupBox Header="Фильтрация по датам" Grid.Row="1" Margin="10">
            <WrapPanel Margin="5">
                <TextBlock Text="Дата с:" VerticalAlignment="Center" Margin="5"/>
                <DatePicker x:Name="StartDatePicker" Width="130" Margin="5" SelectedDateFormat="Short"/>
                <TextBlock Text="по:" VerticalAlignment="Center" Margin="15,5,5,5"/>
                <DatePicker x:Name="EndDatePicker" Width="130" Margin="5" SelectedDateFormat="Short"/>
                <Button Content="Применить фильтр" Click="ApplyFilter_Click" Width="120" Margin="15,5,5,5" Height="28"/>
                <Button Content="Сбросить фильтр" Click="ResetFilter_Click" Width="120" Margin="5" Height="28"/>
                <Button Content="Обновить список" Click="RefreshButton_Click" Width="120" Margin="5" Height="28"/>
            </WrapPanel>
        </GroupBox>

        <!-- Таблица одобренных заявок подразделения -->
        <GroupBox Header="Одобренные заявки" Grid.Row="2" Margin="10">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <DataGrid x:Name="RequestsDataGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          MouseDoubleClick="RequestsDataGrid_MouseDoubleClick" Margin="5"
                          FontSize="12" RowHeight="30" AlternatingRowBackground="LightGray"
                          SelectionMode="Single" SelectionUnit="FullRow">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID заявки" Binding="{Binding RequestId}" Width="70"/>
                        <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="90"/>
                        <DataGridTextColumn Header="Дата начала" Binding="{Binding StartDate, StringFormat=dd.MM.yyyy}" Width="110"/>
                        <DataGridTextColumn Header="Дата окончания" Binding="{Binding EndDate, StringFormat=dd.MM.yyyy}" Width="110"/>
                        <DataGridTextColumn Header="Цель посещения" Binding="{Binding Purpose}" Width="250"/>
                        <DataGridTextColumn Header="Ответственный" Binding="{Binding EmployeeFullName}" Width="180"/>
                        <DataGridTextColumn Header="Посетители" Binding="{Binding VisitorsList}" Width="350"/>
                        <DataGridTextColumn Header="Email заявителя" Binding="{Binding UserEmail}" Width="200"/>
                    </DataGrid.Columns>
                </DataGrid>
            </ScrollViewer>
        </GroupBox>

        <!-- Статусная строка -->
        <StatusBar Grid.Row="3" Margin="5,0,5,5">
            <StatusBarItem>
                <TextBlock x:Name="StatusTextBlock" Text="Готово"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="CountTextBlock" Text="Заявок: 0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>