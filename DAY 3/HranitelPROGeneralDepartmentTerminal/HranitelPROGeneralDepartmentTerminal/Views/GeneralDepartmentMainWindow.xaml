<Window x:Class="HranitelPROGeneralDepartmentTerminal.Views.GeneralDepartmentMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Терминал сотрудника общего отдела" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen" MinHeight="600" MinWidth="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель фильтров -->
        <StackPanel Orientation="Horizontal" Margin="10">
            <TextBlock Text="Тип:" VerticalAlignment="Center" Margin="5,0"/>
            <ComboBox x:Name="TypeFilterComboBox" Width="120" Margin="5">
                <ComboBoxItem Content="Все" IsSelected="True"/>
                <ComboBoxItem Content="personal"/>
                <ComboBoxItem Content="group"/>
            </ComboBox>

            <TextBlock Text="Подразделение:" VerticalAlignment="Center" Margin="20,0,5,0"/>
            <ComboBox x:Name="DepartmentFilterComboBox" Width="180" Margin="5" DisplayMemberPath="name" SelectedValuePath="id"/>

            <TextBlock Text="Статус:" VerticalAlignment="Center" Margin="20,0,5,0"/>
            <ComboBox x:Name="StatusFilterComboBox" Width="140" Margin="5" DisplayMemberPath="name" SelectedValuePath="id"/>

            <Button Content="Применить фильтр" Click="ApplyFilter_Click" Width="130" Margin="20,5,5,5" Height="25"/>
            <Button Content="Сбросить" Click="ResetFilter_Click" Width="100" Margin="5" Height="25"/>
        </StackPanel>

        <!-- Таблица заявок -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <DataGrid x:Name="RequestsDataGrid" AutoGenerateColumns="False" IsReadOnly="True"
                      MouseDoubleClick="RequestsDataGrid_MouseDoubleClick" Margin="10"
                      FontSize="12" RowHeight="25">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding RequestId}" Width="60"/>
                    <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="90"/>
                    <DataGridTextColumn Header="Дата начала" Binding="{Binding StartDate, StringFormat=dd.MM.yyyy}" Width="110"/>
                    <DataGridTextColumn Header="Дата окончания" Binding="{Binding EndDate, StringFormat=dd.MM.yyyy}" Width="110"/>
                    <DataGridTextColumn Header="Цель" Binding="{Binding Purpose}" Width="180"/>
                    <DataGridTextColumn Header="Подразделение" Binding="{Binding DepartmentName}" Width="150"/>
                    <DataGridTextColumn Header="Ответственный" Binding="{Binding EmployeeFullName}" Width="180"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding StatusName}" Width="110"/>
                    <DataGridTextColumn Header="Email заявителя" Binding="{Binding UserEmail}" Width="200"/>
                    <DataGridTextColumn Header="Посетители" Binding="{Binding VisitorsList}" Width="300"/>
                </DataGrid.Columns>
            </DataGrid>
        </ScrollViewer>
    </Grid>
</Window>