<Window x:Class="HranitelPROGeneralDepartmentTerminal.Views.DepartmentMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Терминал сотрудника подразделения" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen" MinHeight="600" MinWidth="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель фильтров -->
        <StackPanel Margin="10">
            <WrapPanel>
                <TextBlock Text="Дата с:" VerticalAlignment="Center" Margin="5"/>
                <DatePicker x:Name="StartDatePicker" Width="120" Margin="5"/>
                <TextBlock Text="по:" VerticalAlignment="Center" Margin="5"/>
                <DatePicker x:Name="EndDatePicker" Width="120" Margin="5"/>
                <Button Content="Применить" Click="ApplyFilter_Click" Width="100" Margin="5"/>
                <Button Content="Сбросить" Click="ResetFilter_Click" Width="80" Margin="5"/>
            </WrapPanel>
        </StackPanel>

        <!-- Таблица одобренных заявок подразделения -->
        <DataGrid x:Name="RequestsDataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                  MouseDoubleClick="RequestsDataGrid_MouseDoubleClick" Margin="10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding RequestId}" Width="50"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="80"/>
                <DataGridTextColumn Header="Дата начала" Binding="{Binding StartDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Дата окончания" Binding="{Binding EndDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Цель" Binding="{Binding Purpose}" Width="200"/>
                <DataGridTextColumn Header="Ответственный" Binding="{Binding EmployeeFullName}" Width="150"/>
                <DataGridTextColumn Header="Посетители" Binding="{Binding VisitorsList}" Width="300"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>