<Page x:Class="HranitelPROGeneralDepartmentTerminal.Views.MyRequestsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Мои заявки">
    <Grid Margin="10">
        <DataGrid x:Name="RequestsDataGrid" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding RequestId}" Width="50"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="80"/>
                <DataGridTextColumn Header="Дата начала" Binding="{Binding StartDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Дата окончания" Binding="{Binding EndDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Цель" Binding="{Binding Purpose}" Width="150"/>
                <DataGridTextColumn Header="Подразделение" Binding="{Binding DepartmentName}" Width="130"/>
                <DataGridTextColumn Header="Ответственный" Binding="{Binding EmployeeFullName}" Width="150"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding StatusName}" Width="100"/>
                <DataGridTextColumn Header="Посетители" Binding="{Binding VisitorsList}" Width="250"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>