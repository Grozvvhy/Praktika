<Window x:Class="HranitelPROGeneralDepartmentTerminal.Views.DepartmentVisitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление посещением - Подразделение" Height="650" Width="950"
        WindowStartupLocation="CenterOwner" MinHeight="550" MinWidth="850">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Информация о заявке -->
            <GroupBox Header="Заявка" Grid.Row="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="ID:"/>
                    <TextBlock x:Name="RequestIdText" Grid.Column="1"/>
                    <TextBlock Text="Тип:" Grid.Column="2"/>
                    <TextBlock x:Name="TypeText" Grid.Column="3"/>
                    <TextBlock Text="Подразделение:" Grid.Row="1"/>
                    <TextBlock x:Name="DepartmentText" Grid.Column="1" Grid.Row="1"/>
                    <TextBlock Text="Ответственный:" Grid.Row="1" Grid.Column="2"/>
                    <TextBlock x:Name="EmployeeText" Grid.Column="3" Grid.Row="1"/>
                    <TextBlock Text="Цель:" Grid.Row="2"/>
                    <TextBlock x:Name="PurposeText" Grid.Column="1" Grid.Row="2" TextWrapping="Wrap" Grid.ColumnSpan="3"/>
                </Grid>
            </GroupBox>

            <!-- Посетители -->
            <GroupBox Header="Посетители" Grid.Row="1" Margin="0,10">
                <DataGrid x:Name="VisitorsDataGrid" AutoGenerateColumns="False" Height="250">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Чёрный список..." Click="AddToBlacklist_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding VisitorId}" Width="50"/>
                        <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="120"/>
                        <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="120"/>
                        <DataGridTextColumn Header="Отчество" Binding="{Binding MiddleName}" Width="120"/>
                        <DataGridTextColumn Header="Вход" Binding="{Binding EntryTime, StringFormat=dd.MM.yyyy HH:mm}" Width="140"/>
                        <DataGridTextColumn Header="Прибытие" Binding="{Binding ArrivalTime, StringFormat=dd.MM.yyyy HH:mm}" Width="140"/>
                        <DataGridTextColumn Header="Убытие" Binding="{Binding DepartureTime, StringFormat=dd.MM.yyyy HH:mm}" Width="140"/>
                        <DataGridCheckBoxColumn Header="Нарушение" Binding="{Binding ViolationTime}" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <!-- Панель действий -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10">
                <Button x:Name="ArrivalButton" Content="Прибыли" Click="ArrivalButton_Click" Width="120" Height="30" Margin="5"/>
                <Button x:Name="DepartureButton" Content="Убыли" Click="DepartureButton_Click" Width="120" Height="30" Margin="5"/>
                <Button Content="Закрыть" Click="CloseButton_Click" Width="100" Height="30" Margin="5"/>
            </StackPanel>

            <TextBlock x:Name="StatusTextBlock" Grid.Row="3" TextWrapping="Wrap" Margin="0,10"/>
        </Grid>
    </ScrollViewer>
</Window>