<Window x:Class="HranitelPROGeneralDepartmentTerminal.Views.SecurityMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Терминал сотрудника охраны" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen" MinHeight="600" MinWidth="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель фильтров и поиска -->
        <StackPanel Margin="10">
            <WrapPanel>
                <TextBlock Text="Дата:" VerticalAlignment="Center" Margin="5"/>
                <DatePicker x:Name="FilterDatePicker" Width="120" Margin="5"/>
                <TextBlock Text="Тип:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox x:Name="TypeFilterComboBox" Width="100" Margin="5">
                    <ComboBoxItem Content="Все" IsSelected="True"/>
                    <ComboBoxItem Content="personal"/>
                    <ComboBoxItem Content="group"/>
                </ComboBox>
                <TextBlock Text="Подразделение:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox x:Name="DepartmentFilterComboBox" Width="150" Margin="5" DisplayMemberPath="name" SelectedValuePath="id"/>
                <Button Content="Применить" Click="ApplyFilter_Click" Width="100" Margin="5"/>
                <Button Content="Сбросить" Click="ResetFilter_Click" Width="80" Margin="5"/>
            </WrapPanel>
            <WrapPanel Margin="0,10,0,0">
                <TextBlock Text="Поиск по ФИО/паспорту:" VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="SearchTextBox" Width="250" Margin="5"/>
                <Button Content="Найти" Click="SearchButton_Click" Width="80" Margin="5"/>
                <Button Content="Сбросить поиск" Click="ResetSearch_Click" Width="120" Margin="5"/>
            </WrapPanel>
        </StackPanel>

        <!-- Таблица одобренных заявок -->
        <DataGrid x:Name="RequestsDataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                  MouseDoubleClick="RequestsDataGrid_MouseDoubleClick" Margin="10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding RequestId}" Width="50"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="80"/>
                <DataGridTextColumn Header="Дата начала" Binding="{Binding StartDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Подразделение" Binding="{Binding DepartmentName}" Width="130"/>
                <DataGridTextColumn Header="Ответственный" Binding="{Binding EmployeeFullName}" Width="150"/>
                <DataGridTextColumn Header="Посетители" Binding="{Binding VisitorsList}" Width="300"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>